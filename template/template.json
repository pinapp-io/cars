    { "id": "fuel",    "label": "Fuel",    "icon": "⛽" },
    { "id": "service", "label": "Service", "icon": "🔧" },
    { "id": "photo",   "label": "Photo",   "icon": "📷" },
    { "id": "note",    "label": "Note",    "icon": "📝" }
