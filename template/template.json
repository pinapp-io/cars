{
  "id": "cars",
  "version": "0.1.0",
  "title": "Cars",
  "description": "A logbook for a vehicle. VIN, photos, fueling and service history, ad-hoc events.",
  "icon": "icon.svg",
  "mintUrl": "mint.html",
  "appUrl": "app.html",
  "fixedAttributes": [
    { "name": "year",  "label": "Year",          "type": "number", "required": true },
    { "name": "make",  "label": "Make",          "type": "string", "required": true },
    { "name": "model", "label": "Model",         "type": "string", "required": true },
    { "name": "vin",   "label": "VIN",           "type": "string" },
